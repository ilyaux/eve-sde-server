# ============================================
# EVE SDE Server Configuration
# ============================================

# Server
PORT=8080

# Database
DB_PATH=data/sde.db

# TLS/HTTPS (Recommended for production)
TLS_ENABLED=false
TLS_CERT_FILE=
TLS_KEY_FILE=

# CORS (comma-separated origins, or "*" for development only)
ALLOWED_ORIGINS=*

# Authentication (Set to "true" to enable API key auth)
AUTH_ENABLED=false

# Auto-update Scheduler
SDE_AUTO_UPDATE=true
SDE_URL=https://eve-static-data-export.s3-eu-west-1.amazonaws.com/tranquility/sde.zip

# ============================================
# Production Settings (Recommended)
# ============================================
# TLS_ENABLED=true
# TLS_CERT_FILE=/path/to/cert.pem
# TLS_KEY_FILE=/path/to/key.pem
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
# AUTH_ENABLED=true
# SDE_AUTO_UPDATE=true
